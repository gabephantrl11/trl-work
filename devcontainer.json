// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-existing-dockerfile
{
	"name": "TRL Work Dev Environment",
	"initializeCommand": "${localWorkspaceFolder}/.devcontainer/setup-env.sh",
	"build": {
		"context": "..",
		"dockerfile": "./Dockerfile",
		"args": {
			"NODE_VERSION": "${localEnv:NODE_VERSION:24.11.1}",
			"NVM_VERSION": "${localEnv:NVM_VERSION:0.40.2}",
			"PYTHON_VERSION": "${localEnv:PYTHON_VERSION:3.10}",
			"UBUNTU_VERSION": "${localEnv:UBUNTU_VERSION:22.04}"
		}
	},
	"runArgs": [
		"--name", "trl-work-devcontainer",
		"--hostname", "devcontainer",
		"--add-host=devcontainer:127.0.0.1",
		"--env-file", "${localWorkspaceFolder}/.devcontainer/.env",
		"--privileged",
		"--cgroupns=host",
		"--network=host",
		"--security-opt", "apparmor=unconfined",
		"--shm-size", "1g",
		"-e", "DISPLAY=${env:DISPLAY}",
		"-e", "TZ=${localEnv:TZ}"
	],
	"workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/trl-work,type=bind,consistency=cached",
	"workspaceFolder": "/workspaces/trl-work",
	"mounts": [
		"source=${env:HOME}/.cache,target=/home/dev/.cache,type=bind",
		"source=${env:HOME}/.gitconfig,target=/home/dev/.gitconfig,type=bind",
		"source=${env:HOME}/.npm,target=/home/dev/.npm,type=bind",
		"source=${env:HOME}/.ssh,target=/home/dev/.ssh,type=bind",
		"source=${env:HOME}/.claude,target=/home/dev/.claude,type=bind",
		"source=/dev,target=/dev,type=bind",
		"source=/etc/localtime,target=/etc/localtime,type=bind,readonly",
		"source=/etc/timezone,target=/etc/timezone,type=bind,readonly",
		"source=/tmp,target=/tmp,type=bind",
		"source=/var/run/dbus,target=/var/run/dbus,type=bind",
		"source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
	],
	"customizations": {
		"vscode": {
			"extensions": [
				"charliermarsh.ruff",
				"dbaeumer.vscode-eslint",
				"docker.docker",
				"esbenp.prettier-vscode",
				"mhutchie.git-graph",
				"ms-azuretools.vscode-docker",
				"ms-python.python",
				"ms-python.vscode-pylance",
				"ms-vscode.cmake-tools",
				"ms-vscode.cpptools",
				"mutantdino.resourcemonitor",
				"streetsidesoftware.code-spell-checker",
				"tamasfe.even-better-toml",
				"xaver.clang-format"
			],
			"settings": {
				"editor.formatOnSave": true,
				"files.watcherExclude": {
					"**/build/**": true,
					"**/node_modules/**": true,
					"**/.pytest_cache/**": true
				},
				"[python]": {
					"editor.defaultFormatter": "charliermarsh.ruff"
				},
				"remote.autoForwardPorts": false,
				"terminal.integrated.profiles.linux": {
					"bash": {
						"path": "/bin/bash",
						"args": [
							"--init-file",
							"${containerWorkspaceFolder}/.devcontainer/devcontainer.entrypoint.sh"
						]
					}
				},
				"terminal.integrated.defaultProfile.linux": "bash",
				"terminal.integrated.allowChords": false,
				"terminal.integrated.shellIntegration.enabled": true
			}
		}
	},
	"containerEnv": {
		"WORKSPACE_VOLUME": "${localWorkspaceFolder}",
		"WORKSPACE_DIR": "/workspaces/trl-work",
		"TRL11_DEV_CONTAINER": "true",
		"DBUS_SYSTEM_BUS_ADDRESS": "unix:path=/var/run/dbus/system_bus_socket",
		"XDG_RUNTIME_DIR": "/tmp/runtime-dev"
	},
	"remoteUser": "dev",
	"overrideCommand": true,
	"postStartCommand": "/workspaces/trl-work/.devcontainer/devcontainer.entrypoint.sh"
}
